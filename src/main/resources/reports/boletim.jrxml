<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="boletim"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

    <!-- ═══ STYLES ═══════════════════════════════════════════════════════ -->
    <style name="default" isDefault="true" fontName="SansSerif" fontSize="8" forecolor="#000000"/>

    <style name="mediaStyle" fontName="SansSerif" fontSize="8" isBold="true">
        <conditionalStyle>
            <conditionExpression><![CDATA[$F{mediaAnualDouble} != null && $F{mediaAnualDouble} < 6.0]]></conditionExpression>
            <style forecolor="#b94040"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA[$F{mediaAnualDouble} != null && $F{mediaAnualDouble} >= 6.0]]></conditionExpression>
            <style forecolor="#2d6a4f"/>
        </conditionalStyle>
    </style>

    <style name="freqStyle" fontName="SansSerif" fontSize="8" isBold="true">
        <conditionalStyle>
            <conditionExpression><![CDATA[$F{frequenciaDouble} != null && $F{frequenciaDouble} < 75.0]]></conditionExpression>
            <style forecolor="#b94040"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA[$F{frequenciaDouble} != null && $F{frequenciaDouble} >= 75.0]]></conditionExpression>
            <style forecolor="#2d6a4f"/>
        </conditionalStyle>
    </style>

    <style name="sitStyle" fontName="SansSerif" fontSize="8" isBold="true">
        <conditionalStyle>
            <conditionExpression><![CDATA["Aprovado".equals($F{situacao})]]></conditionExpression>
            <style forecolor="#2d6a4f"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA["Reprovado".equals($F{situacao})]]></conditionExpression>
            <style forecolor="#b94040"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA["Em curso".equals($F{situacao})]]></conditionExpression>
            <style forecolor="#888888"/>
        </conditionalStyle>
    </style>

    <style name="resultadoStyle" fontName="SansSerif" fontSize="10" isBold="true">
        <conditionalStyle>
            <conditionExpression><![CDATA["Aprovado".equals($P{RESULTADO_FINAL})]]></conditionExpression>
            <style forecolor="#2d6a4f"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA["Reprovado".equals($P{RESULTADO_FINAL})]]></conditionExpression>
            <style forecolor="#b94040"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA["Em curso".equals($P{RESULTADO_FINAL})]]></conditionExpression>
            <style forecolor="#888888"/>
        </conditionalStyle>
    </style>

    <!-- ═══ PARAMETERS ═══════════════════════════════════════════════════ -->
    <parameter name="ALUNO_NOME"      class="java.lang.String"/>
    <parameter name="ALUNO_ID"        class="java.lang.Long"/>
    <parameter name="TURMA_NOME"      class="java.lang.String"/>
    <parameter name="SERIE_NOME"      class="java.lang.String"/>
    <parameter name="ANO_LETIVO"      class="java.lang.Integer"/>
    <parameter name="FREQ_GERAL"      class="java.lang.String"/>
    <parameter name="RESULTADO_FINAL" class="java.lang.String"/>
    <parameter name="DATA_EMISSAO"    class="java.lang.String"/>

    <!-- ═══ FIELDS ═══════════════════════════════════════════════════════ -->
    <field name="materiaNome"       class="java.lang.String"/>
    <field name="media1"            class="java.lang.String"/>
    <field name="faltas1"           class="java.lang.Integer"/>
    <field name="media2"            class="java.lang.String"/>
    <field name="faltas2"           class="java.lang.Integer"/>
    <field name="media3"            class="java.lang.String"/>
    <field name="faltas3"           class="java.lang.Integer"/>
    <field name="media4"            class="java.lang.String"/>
    <field name="faltas4"           class="java.lang.Integer"/>
    <field name="mediaAnual"        class="java.lang.String"/>
    <field name="totalFaltas"       class="java.lang.Integer"/>
    <field name="frequencia"        class="java.lang.String"/>
    <field name="situacao"          class="java.lang.String"/>
    <field name="mediaAnualDouble"  class="java.lang.Double"/>
    <field name="frequenciaDouble"  class="java.lang.Double"/>

    <!-- ═══ VARIABLES ════════════════════════════════════════════════════ -->
    <variable name="ROW_COUNT" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[1]]></variableExpression>
    </variable>

    <!-- ═══ TITLE (header + student info + table column headers) ═════════ -->
    <title>
        <band height="96" splitType="Stretch">

            <!-- Title bar -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="18" backcolor="#d0d0d0" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="2" width="555" height="14"/>
                <textElement textAlignment="Center">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[BOLETIM ESCOLAR]]></text>
            </staticText>

            <!-- Emission date -->
            <textField>
                <reportElement x="380" y="22" width="175" height="10" forecolor="#555555"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Emissão: " + $P{DATA_EMISSAO}]]></textFieldExpression>
            </textField>

            <!-- Student info box (row 1) -->
            <rectangle>
                <reportElement x="0" y="34" width="555" height="26" mode="Opaque" backcolor="#ffffff"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#aaaaaa"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="4" y="37" width="55" height="10"/>
                <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Matrícula:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="37" width="80" height="10"/>
                <textElement><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[String.valueOf($P{ALUNO_ID})]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="150" y="37" width="38" height="10"/>
                <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Aluno(a):]]></text>
            </staticText>
            <textField>
                <reportElement x="190" y="37" width="210" height="10"/>
                <textElement><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{ALUNO_NOME}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="410" y="37" width="55" height="10"/>
                <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Ano Letivo:]]></text>
            </staticText>
            <textField>
                <reportElement x="468" y="37" width="83" height="10"/>
                <textElement><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[String.valueOf($P{ANO_LETIVO})]]></textFieldExpression>
            </textField>

            <!-- Student info box (row 2) -->
            <staticText>
                <reportElement x="4" y="50" width="35" height="10"/>
                <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Turma:]]></text>
            </staticText>
            <textField>
                <reportElement x="40" y="50" width="120" height="10"/>
                <textElement><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{TURMA_NOME}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="170" y="50" width="30" height="10"/>
                <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Série:]]></text>
            </staticText>
            <textField>
                <reportElement x="202" y="50" width="200" height="10"/>
                <textElement><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{SERIE_NOME}]]></textFieldExpression>
            </textField>

            <!-- ── Table bimestre group headers ── -->
            <!-- Row 1: Bimestre group labels -->
            <rectangle>
                <reportElement x="0" y="66" width="555" height="16" backcolor="#e8e8e8" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </rectangle>
            <!-- Disciplina -->
            <staticText>
                <reportElement x="2" y="68" width="140" height="12"/>
                <textElement><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[Disciplina]]></text>
            </staticText>
            <!-- 1º Bim -->
            <staticText>
                <reportElement x="142" y="68" width="62" height="12"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[1º Bim]]></text>
            </staticText>
            <!-- 2º Bim -->
            <staticText>
                <reportElement x="204" y="68" width="62" height="12"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[2º Bim]]></text>
            </staticText>
            <!-- 3º Bim -->
            <staticText>
                <reportElement x="266" y="68" width="62" height="12"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[3º Bim]]></text>
            </staticText>
            <!-- 4º Bim -->
            <staticText>
                <reportElement x="328" y="68" width="62" height="12"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[4º Bim]]></text>
            </staticText>
            <!-- RESULTADO label -->
            <staticText>
                <reportElement x="390" y="68" width="165" height="12"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[RESULTADO]]></text>
            </staticText>

            <!-- Row 2: Column sub-headers -->
            <rectangle>
                <reportElement x="0" y="82" width="555" height="14" backcolor="#eeeeee" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="2" y="84" width="140" height="10"/>
                <textElement><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[Disciplina]]></text>
            </staticText>
            <!-- Bim 1 -->
            <staticText>
                <reportElement x="142" y="84" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Nota]]></text>
            </staticText>
            <staticText>
                <reportElement x="178" y="84" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[F]]></text>
            </staticText>
            <!-- Bim 2 -->
            <staticText>
                <reportElement x="204" y="84" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Nota]]></text>
            </staticText>
            <staticText>
                <reportElement x="240" y="84" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[F]]></text>
            </staticText>
            <!-- Bim 3 -->
            <staticText>
                <reportElement x="266" y="84" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Nota]]></text>
            </staticText>
            <staticText>
                <reportElement x="302" y="84" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[F]]></text>
            </staticText>
            <!-- Bim 4 -->
            <staticText>
                <reportElement x="328" y="84" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Nota]]></text>
            </staticText>
            <staticText>
                <reportElement x="364" y="84" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[F]]></text>
            </staticText>
            <!-- Resultado cols -->
            <staticText>
                <reportElement x="390" y="84" width="38" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Média]]></text>
            </staticText>
            <staticText>
                <reportElement x="428" y="84" width="28" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[T.F]]></text>
            </staticText>
            <staticText>
                <reportElement x="456" y="84" width="42" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Freq%]]></text>
            </staticText>
            <staticText>
                <reportElement x="498" y="84" width="57" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="6" isBold="true"/></textElement>
                <text><![CDATA[Situação]]></text>
            </staticText>

            <!-- Vertical separators on subheader -->
            <line>
                <reportElement x="142" y="66" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <line>
                <reportElement x="204" y="66" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <line>
                <reportElement x="266" y="66" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <line>
                <reportElement x="328" y="66" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <line>
                <reportElement x="390" y="66" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <line>
                <reportElement x="178" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="240" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="302" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="364" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="428" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="456" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="498" y="82" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>

        </band>
    </title>

    <!-- ═══ DETAIL (one row per disciplina) ══════════════════════════════ -->
    <detail>
        <band height="14" splitType="Stretch">

            <!-- Alternating row background -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="14" backcolor="#f5f5f5" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{ROW_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <!-- Bottom border -->
            <line>
                <reportElement x="0" y="13" width="555" height="0"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#dddddd"/></graphicElement>
            </line>

            <!-- Disciplina -->
            <textField isStretchWithOverflow="true">
                <reportElement x="2" y="2" width="138" height="10"/>
                <textElement><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{materiaNome}]]></textFieldExpression>
            </textField>

            <!-- Bim 1 -->
            <textField>
                <reportElement x="142" y="2" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{media1} != null ? $F{media1} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="178" y="2" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{faltas1} != null ? String.valueOf($F{faltas1}) : "—"]]></textFieldExpression>
            </textField>

            <!-- Bim 2 -->
            <textField>
                <reportElement x="204" y="2" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{media2} != null ? $F{media2} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="240" y="2" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{faltas2} != null ? String.valueOf($F{faltas2}) : "—"]]></textFieldExpression>
            </textField>

            <!-- Bim 3 -->
            <textField>
                <reportElement x="266" y="2" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{media3} != null ? $F{media3} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="302" y="2" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{faltas3} != null ? String.valueOf($F{faltas3}) : "—"]]></textFieldExpression>
            </textField>

            <!-- Bim 4 -->
            <textField>
                <reportElement x="328" y="2" width="36" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{media4} != null ? $F{media4} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="364" y="2" width="26" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{faltas4} != null ? String.valueOf($F{faltas4}) : "—"]]></textFieldExpression>
            </textField>

            <!-- Média Anual (colored) -->
            <textField>
                <reportElement x="390" y="2" width="38" height="10" style="mediaStyle"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{mediaAnual} != null ? $F{mediaAnual} : "—"]]></textFieldExpression>
            </textField>

            <!-- Total Faltas -->
            <textField>
                <reportElement x="428" y="2" width="28" height="10"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{totalFaltas} != null ? String.valueOf($F{totalFaltas}) : "0"]]></textFieldExpression>
            </textField>

            <!-- Frequência (colored) -->
            <textField>
                <reportElement x="456" y="2" width="42" height="10" style="freqStyle"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{frequencia} != null ? $F{frequencia} : "—"]]></textFieldExpression>
            </textField>

            <!-- Situação (colored) -->
            <textField>
                <reportElement x="498" y="2" width="57" height="10" style="sitStyle"/>
                <textElement textAlignment="Center"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{situacao} != null ? $F{situacao} : "—"]]></textFieldExpression>
            </textField>

            <!-- Column vertical separators -->
            <line>
                <reportElement x="142" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="178" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="204" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="240" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="266" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="302" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="328" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="364" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="390" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="428" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="456" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
            <line>
                <reportElement x="498" y="0" width="0" height="14"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#cccccc"/></graphicElement>
            </line>
        </band>
    </detail>

    <!-- ═══ SUMMARY (freq geral + resultado + legenda + recibo) ══════════ -->
    <summary>
        <band height="140" splitType="Stretch">

            <!-- Top border -->
            <line>
                <reportElement x="0" y="0" width="555" height="0"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </line>

            <!-- Resultado final box -->
            <rectangle>
                <reportElement x="0" y="4" width="555" height="26" backcolor="#f0f0f0" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#aaaaaa"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="8" width="110" height="12"/>
